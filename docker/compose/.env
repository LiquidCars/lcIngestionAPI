# --- Server & Security ---
SERVER_PORT=8890
KEYCLOAK_ISSUER=http://keycloak:8080/realms/
CORS_ALLOWED_ORIGINS=*
SECURITY_MAX_BATCH_SIZE=10MB

# --- PostgreSQL (Main Datasource) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/liquidcars?charSet=UTF8
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- MongoDB Configuration ---
JDBC_URL=mongodb://ingestion_service:mongo@mongodb:27017/ingestion_service?authSource=admin
SPRING_MONGO_URL=mongodb://ingestion_service:mongo@mongodb:27017/ingestion_service?authSource=admin
LIQUIBASE_MONGO_URL=mongodb://ingestion_service:mongo@mongodb:27017/ingestion_service?authSource=admin

# Mongo container credentials (Root)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=mongo
MONGO_DATABASE=admin

# --- Kafka Configuration ---
KAFKA_ENABLED=true
KAFKA_HOST=kafka:29092
KAFKA_USER=ingestion-service
KAFKA_PWD=CReUJCx6TaGKFyNTLPVttEby2EBtZ2UE
KAFKA_SECURITY=PLAINTEXT

# Broker Listeners
KAFKA_LISTENERS=INTERNAL://:29092,EXTERNAL://:9092
KAFKA_ADVERTISED_LISTENERS=INTERNAL://kafka:29092,EXTERNAL://localhost:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=INTERNAL
KAFKA_BROKERCONNECT=kafka:29092

# Retry timers
KAFKA_ZOOKEEPER_SESSION_TIMEOUT=6000
KAFKA_RESTART_ATTEMPTS=10
KAFKA_RESTART_DELAY=5
ZOOKEEPER_AUTOPURGE_PURGE_INTERVAL=0

# --- App Specific (Ingestion) ---
OFFERS_TEST_URL=http://localhost:8083/offers.json