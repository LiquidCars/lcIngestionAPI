# --- Server & Security ---
SERVER_PORT=8890
KEYCLOAK_ISSUER=http://keycloak:8080/realms/
CORS_ALLOWED_ORIGINS=*
SECURITY_MAX_BATCH_SIZE=10MB

# --- PostgreSQL (Main Datasource) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/liquidcars?charSet=UTF8
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- MongoDB Configuration ---
SPRING_MONGO_URL=mongodb://liquidcars_service:mongo@mongodb:27017/liquidcars_service?authSource=admin
LIQUIBASE_MONGO_URL=mongodb://mongodb:27017/liquidcars_service?authSource=admin

# Mongo container credentials (Root)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=mongo
MONGO_DATABASE=admin

# --- Kafka Configuration ---
# --- Zookeeper ---
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# --- Kafka Core ---
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# --- Kafka Ports ---
KAFKA_EXTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT2=9094

# --- Kafka Listeners ---
KAFKA_LISTENERS=INTERNAL://:29092,EXTERNAL://:9092,DOCKER_BRIDGE://:9094
KAFKA_ADVERTISED_LISTENERS=INTERNAL://kafka:29092,EXTERNAL://localhost:9092,DOCKER_BRIDGE://kafka:9094
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,DOCKER_BRIDGE:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=INTERNAL
# --- Kafka Transactions (IMPORTANT) ---
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1

# --- Kafka Stability ---
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0

# --- Kafka Clients ---
KAFKA_HOST=kafka:29092
KAFKA_BROKERCONNECT=kafka:29092

# --- App Specific (Ingestion) ---
JDBC_BATCH_SIZE=500
BATCH_CHUNK_SIZE=500
BATCH_SKIP_LIMIT=10
BATCH_QUEUE_SIZE=5000